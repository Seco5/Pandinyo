{
  "metadata": {
    "total_phrases": 160,
    "categories": 8
  },
  "categories": [
    {
      "id": "meeting",
      "title": "Toplantı Dili",
      "icon": "users",
      "color": "#7C3AED",
      "phrases": [
        { "id": "m01", "english": "Let's kick things off.", "turkish": "Başlayalım.", "context": "Toplantıyı açarken", "level": "beginner" },
        { "id": "m02", "english": "Shall we get started?", "turkish": "Başlasak mı?", "context": "Toplantıyı açarken", "level": "beginner" },
        { "id": "m03", "english": "Let's go around the table.", "turkish": "Sırayla herkes konuşsun.", "context": "Herkesten görüş alırken", "level": "intermediate" },
        { "id": "m04", "english": "I'd like to flag a risk.", "turkish": "Bir riski belirtmek istiyorum.", "context": "Endişeni dile getirirken", "level": "intermediate" },
        { "id": "m05", "english": "Can we table that for now?", "turkish": "Bunu şimdilik erteleyebilir miyiz?", "context": "Konuyu sonraya bırakırken", "level": "intermediate" },
        { "id": "m06", "english": "Let's circle back to that.", "turkish": "Buna sonra dönelim.", "context": "Konuyu erteleyerek ilerlerken", "level": "intermediate" },
        { "id": "m07", "english": "If I may, I'd like to add something.", "turkish": "İzin verirseniz bir şey eklemek istiyorum.", "context": "Söz almak istediğinde", "level": "intermediate" },
        { "id": "m08", "english": "Building on what you just said...", "turkish": "Söylediklerinin üzerine ekleyerek...", "context": "Birinin fikrini geliştirirken", "level": "intermediate" },
        { "id": "m09", "english": "I'd like to push back on that.", "turkish": "Buna katılmıyorum / itiraz etmek istiyorum.", "context": "Nazikçe itiraz ederken", "level": "advanced" },
        { "id": "m10", "english": "That's a fair point.", "turkish": "Bu geçerli bir nokta.", "context": "Birinin görüşünü kabul ederken", "level": "beginner" },
        { "id": "m11", "english": "Can you elaborate on that?", "turkish": "Biraz daha açar mısın?", "context": "Daha fazla detay isterken", "level": "intermediate" },
        { "id": "m12", "english": "Can we get consensus on this?", "turkish": "Bu konuda fikir birliği sağlayabilir miyiz?", "context": "Karar almaya çalışırken", "level": "intermediate" },
        { "id": "m13", "english": "Let's put a pin in that.", "turkish": "Bunu not edelim, sonra ele alalım.", "context": "Konuyu kaydetmek ama ilerlemek istediğinde", "level": "advanced" },
        { "id": "m14", "english": "We're running low on time.", "turkish": "Zamanımız azalıyor.", "context": "Toplantı uzadığında", "level": "beginner" },
        { "id": "m15", "english": "To summarize what we've discussed...", "turkish": "Görüştüklerimizi özetlemek gerekirse...", "context": "Toplantıyı kapatırken", "level": "beginner" },
        { "id": "m16", "english": "Let's take this offline.", "turkish": "Bunu toplantı dışında konuşalım.", "context": "İkili konuşmaya taşımak istediğinde", "level": "intermediate" },
        { "id": "m17", "english": "I think we're aligned on this.", "turkish": "Sanırım bu konuda hemfikiriz.", "context": "Anlaşmaya varıldığında", "level": "beginner" },
        { "id": "m18", "english": "Let me jump in here.", "turkish": "Burada araya gireyim.", "context": "Söze girmek istediğinde", "level": "intermediate" },
        { "id": "m19", "english": "Does anyone have any objections?", "turkish": "Herhangi bir itirazı olan var mı?", "context": "Kararı sonlandırırken", "level": "beginner" },
        { "id": "m20", "english": "Who owns this action item?", "turkish": "Bu maddeyi kim üstleniyor?", "context": "Görev dağılımı yaparken", "level": "intermediate" }
      ]
    },
    {
      "id": "online_meeting",
      "title": "Online Toplantı",
      "icon": "video",
      "color": "#0369A1",
      "phrases": [
        { "id": "o01", "english": "I think you're on mute.", "turkish": "Sanırım sesiniz kapalı.", "context": "Karşı taraf duyulmadığında", "level": "beginner" },
        { "id": "o02", "english": "Sorry, you're breaking up.", "turkish": "Özür dilerim, sesiniz kesik geliyor.", "context": "Bağlantı kötüyken", "level": "beginner" },
        { "id": "o03", "english": "Can you hear me now?", "turkish": "Şimdi duyabiliyor musunuz?", "context": "Sesin gelip gelmediğini kontrol ederken", "level": "beginner" },
        { "id": "o04", "english": "Could you share your screen?", "turkish": "Ekranınızı paylaşabilir misiniz?", "context": "Ekran paylaşımı isterken", "level": "beginner" },
        { "id": "o05", "english": "I'll drop the link in the chat.", "turkish": "Linki sohbete bırakacağım.", "context": "Dosya veya link paylaşırken", "level": "beginner" },
        { "id": "o06", "english": "Sorry, I was on mute.", "turkish": "Özür dilerim, sesim kapalıydı.", "context": "Farkında olmadan sesini kapattığında", "level": "beginner" },
        { "id": "o07", "english": "Let me just share my screen.", "turkish": "Ekranımı paylaşayım.", "context": "Sunum yapmaya başlarken", "level": "beginner" },
        { "id": "o08", "english": "I'm having some connection issues.", "turkish": "Bağlantı sorunum var.", "context": "İnternet problemi yaşadığında", "level": "beginner" },
        { "id": "o09", "english": "Can everyone see my screen?", "turkish": "Herkes ekranımı görebiliyor mu?", "context": "Ekran paylaşımı başlattıktan sonra", "level": "beginner" },
        { "id": "o10", "english": "There seems to be an echo.", "turkish": "Yankı var gibi görünüyor.", "context": "Ses yankılandığında", "level": "intermediate" },
        { "id": "o11", "english": "Could you turn on your camera?", "turkish": "Kameranızı açabilir misiniz?", "context": "Görüntü isterken", "level": "beginner" },
        { "id": "o12", "english": "I'll send the recording afterwards.", "turkish": "Kaydı sonradan göndereceğim.", "context": "Toplantı kaydedildiğinde", "level": "beginner" },
        { "id": "o13", "english": "Sorry, I missed that. Could you repeat?", "turkish": "Özür dilerim, kaçırdım. Tekrar edebilir misiniz?", "context": "Bir şeyi duymadığında", "level": "beginner" },
        { "id": "o14", "english": "Let's use the chat for questions.", "turkish": "Soruları sohbet bölümünden soralım.", "context": "Toplantı düzenini belirlerken", "level": "beginner" },
        { "id": "o15", "english": "Can you please mute yourself?", "turkish": "Lütfen sesinizi kapatır mısınız?", "context": "Arka plan gürültüsü varken", "level": "beginner" },
        { "id": "o16", "english": "I think we lost someone.", "turkish": "Birini kaybettik sanırım.", "context": "Birinin bağlantısı koptuğunda", "level": "beginner" },
        { "id": "o17", "english": "Could you speak up a bit?", "turkish": "Biraz daha yüksek sesle konuşabilir misiniz?", "context": "Ses alçak geldiğinde", "level": "beginner" },
        { "id": "o18", "english": "Let's give them a moment to reconnect.", "turkish": "Yeniden bağlanmaları için bir dakika verelim.", "context": "Birinin bağlantısı koptuğunda", "level": "intermediate" },
        { "id": "o19", "english": "I'll put the notes in the chat.", "turkish": "Notları sohbete yazacağım.", "context": "Bilgi paylaşırken", "level": "beginner" },
        { "id": "o20", "english": "Let's do a quick sound check.", "turkish": "Hızlı bir ses kontrolü yapalım.", "context": "Toplantı başında", "level": "beginner" }
      ]
    },
    {
      "id": "email",
      "title": "E-posta Kalıpları",
      "icon": "mail",
      "color": "#059669",
      "phrases": [
        { "id": "e01", "english": "I hope this email finds you well.", "turkish": "Umarım iyisinizdir.", "context": "E-postaya başlarken", "level": "beginner" },
        { "id": "e02", "english": "Please find attached...", "turkish": "Ekte bulabilirsiniz...", "context": "Dosya eklerken", "level": "beginner" },
        { "id": "e03", "english": "I am writing to inform you that...", "turkish": "Size ... hakkında bilgi vermek için yazıyorum.", "context": "Resmi bildirim yaparken", "level": "beginner" },
        { "id": "e04", "english": "As per our previous conversation...", "turkish": "Önceki görüşmemizde belirtildiği üzere...", "context": "Önceki konuşmaya atıfta bulunurken", "level": "intermediate" },
        { "id": "e05", "english": "I would appreciate it if you could...", "turkish": "Yapabilirseniz memnun olurum...", "context": "Nazikçe bir şey isterken", "level": "intermediate" },
        { "id": "e06", "english": "Could you please revert by end of day?", "turkish": "Gün sonuna kadar dönebilir misiniz?", "context": "Hızlı yanıt isterken", "level": "intermediate" },
        { "id": "e07", "english": "I wanted to follow up on my previous email.", "turkish": "Önceki e-postamı takip etmek istedim.", "context": "Yanıt gelmediğinde", "level": "beginner" },
        { "id": "e08", "english": "Please let me know if you have any questions.", "turkish": "Sorularınız olursa lütfen bildirin.", "context": "E-postayı kapatırken", "level": "beginner" },
        { "id": "e09", "english": "I sincerely apologize for the inconvenience.", "turkish": "Yaşanan rahatsızlık için içtenlikle özür dilerim.", "context": "Özür e-postasında", "level": "intermediate" },
        { "id": "e10", "english": "Thank you for bringing this to my attention.", "turkish": "Bunu dikkatime sunduğunuz için teşekkürler.", "context": "Şikayet veya bildirim alındığında", "level": "intermediate" },
        { "id": "e11", "english": "I look forward to hearing from you.", "turkish": "Yanıtınızı sabırsızlıkla bekliyorum.", "context": "E-postayı kapatırken", "level": "beginner" },
        { "id": "e12", "english": "Please do not hesitate to contact me.", "turkish": "Benimle iletişime geçmekten çekinmeyin.", "context": "Kapanışta", "level": "beginner" },
        { "id": "e13", "english": "Further to our discussion...", "turkish": "Görüşmemizin devamı olarak...", "context": "Toplantı sonrası e-postada", "level": "advanced" },
        { "id": "e14", "english": "I wanted to touch base regarding...", "turkish": "... konusunda görüşmek istedim.", "context": "Kısa bilgi almak için", "level": "intermediate" },
        { "id": "e15", "english": "As a matter of urgency...", "turkish": "Acilen...", "context": "Acil durumları bildirirken", "level": "advanced" },
        { "id": "e16", "english": "I am happy to arrange a call if needed.", "turkish": "Gerekirse bir görüşme ayarlayabilirim.", "context": "Esnek olduğunu gösterirken", "level": "intermediate" },
        { "id": "e17", "english": "Please confirm receipt of this email.", "turkish": "Bu e-postayı aldığınızı lütfen teyit edin.", "context": "Teyit isterken", "level": "intermediate" },
        { "id": "e18", "english": "I will keep you updated.", "turkish": "Sizi güncel tutacağım.", "context": "Takip sözü verirken", "level": "beginner" },
        { "id": "e19", "english": "Would it be possible to...", "turkish": "... mümkün olabilir mi?", "context": "Nazikçe talepte bulunurken", "level": "beginner" },
        { "id": "e20", "english": "I appreciate your prompt response.", "turkish": "Hızlı yanıtınız için teşekkür ederim.", "context": "Hızlı cevap alındığında", "level": "intermediate" }
      ]
    },
    {
      "id": "phone",
      "title": "Telefon Görüşmesi",
      "icon": "phone",
      "color": "#B45309",
      "phrases": [
        { "id": "p01", "english": "Good morning, [Name] speaking. How can I help you?", "turkish": "Günaydın, [İsim] konuşuyor. Size nasıl yardımcı olabilirim?", "context": "Telefonu açarken", "level": "beginner" },
        { "id": "p02", "english": "Could I speak to [Name], please?", "turkish": "[İsim] ile konuşabilir miyim lütfen?", "context": "Birini ararken", "level": "beginner" },
        { "id": "p03", "english": "I'm afraid they're not available at the moment.", "turkish": "Korkarım şu an müsait değiller.", "context": "Aranan kişi yokken", "level": "beginner" },
        { "id": "p04", "english": "Could I take a message?", "turkish": "Mesaj alabilir miyim?", "context": "Mesaj almak istediğinde", "level": "beginner" },
        { "id": "p05", "english": "I'll have them call you back.", "turkish": "Sizi geri aramalarını sağlarım.", "context": "Geri arama söz verirken", "level": "beginner" },
        { "id": "p06", "english": "Could you hold the line, please?", "turkish": "Lütfen hatta kalır mısınız?", "context": "Bekletirken", "level": "beginner" },
        { "id": "p07", "english": "I'm calling regarding...", "turkish": "... konusunda arıyorum.", "context": "Aramanın amacını belirtirken", "level": "beginner" },
        { "id": "p08", "english": "I'm sorry, could you repeat that?", "turkish": "Özür dilerim, tekrar eder misiniz?", "context": "Bir şeyi anlamadığında", "level": "beginner" },
        { "id": "p09", "english": "Could you speak up, please?", "turkish": "Daha yüksek sesle konuşabilir misiniz?", "context": "Ses alçak geldiğinde", "level": "beginner" },
        { "id": "p10", "english": "Let me transfer you to the right department.", "turkish": "Sizi doğru departmana bağlayayım.", "context": "Transfer ederken", "level": "intermediate" },
        { "id": "p11", "english": "I'll look into this and get back to you.", "turkish": "Araştırıp size döneceğim.", "context": "Hemen cevap veremediğinde", "level": "intermediate" },
        { "id": "p12", "english": "Thank you for calling. Have a good day.", "turkish": "Aradığınız için teşekkürler. İyi günler.", "context": "Görüşmeyi bitirirken", "level": "beginner" },
        { "id": "p13", "english": "Is this a good time to talk?", "turkish": "Şu an konuşmak için uygun mu?", "context": "Aramadan önce kontrol ederken", "level": "beginner" },
        { "id": "p14", "english": "I'm afraid I can't discuss this over the phone.", "turkish": "Korkarım bunu telefonda görüşemem.", "context": "Hassas konu için", "level": "advanced" },
        { "id": "p15", "english": "Can I confirm your contact details?", "turkish": "İletişim bilgilerinizi teyit edebilir miyim?", "context": "Bilgi doğrularken", "level": "intermediate" },
        { "id": "p16", "english": "I'll send you a follow-up email.", "turkish": "Size takip e-postası göndereceğim.", "context": "Görüşme sonrası", "level": "beginner" },
        { "id": "p17", "english": "Let me check that for you.", "turkish": "Sizin için kontrol edeyim.", "context": "Bilgi ararken", "level": "beginner" },
        { "id": "p18", "english": "I apologize for the wait.", "turkish": "Beklettiğim için özür dilerim.", "context": "Bekletme sonrası", "level": "beginner" },
        { "id": "p19", "english": "Could we schedule a call for tomorrow?", "turkish": "Yarın için bir görüşme planlayabilir miyiz?", "context": "Randevu alırken", "level": "beginner" },
        { "id": "p20", "english": "I'm losing you. Let me call you back.", "turkish": "Sesiniz gitmeye başladı. Sizi geri arayayım.", "context": "Bağlantı kopunca", "level": "beginner" }
      ]
    },
    {
      "id": "interview",
      "title": "İş Mülakatı",
      "icon": "briefcase",
      "color": "#DC2626",
      "phrases": [
        { "id": "i01", "english": "Thank you for having me. It's a pleasure to be here.", "turkish": "Davet ettiğiniz için teşekkürler. Burada olmak bir zevk.", "context": "Mülakatta açılışta", "level": "beginner" },
        { "id": "i02", "english": "I've been looking forward to this opportunity.", "turkish": "Bu fırsatı sabırsızlıkla bekliyordum.", "context": "Mülakatta coşkunu gösterirken", "level": "intermediate" },
        { "id": "i03", "english": "In my previous role, I was responsible for...", "turkish": "Önceki rolümde ... sorumluluğunu üstlendim.", "category": "Deneyimi anlatırken", "level": "beginner" },
        { "id": "i04", "english": "One of my key achievements was...", "turkish": "Temel başarılarımdan biri ...", "context": "Başarıları aktarırken", "level": "intermediate" },
        { "id": "i05", "english": "I thrive in fast-paced environments.", "turkish": "Hızlı tempolu ortamlarda verimli çalışırım.", "context": "Çalışma tarzını anlatırken", "level": "advanced" },
        { "id": "i06", "english": "I'm particularly drawn to this role because...", "turkish": "Bu role özellikle ilgi duyuyorum çünkü...", "context": "Motivasyonunu anlatırken", "level": "intermediate" },
        { "id": "i07", "english": "That's a great question. Let me think for a moment.", "turkish": "Harika bir soru. Bir düşüneyim.", "context": "Zor soruya hazırlanırken", "level": "beginner" },
        { "id": "i08", "english": "I'd describe myself as...", "turkish": "Kendimi ... olarak tanımlarım.", "context": "Kişilik sorusuna cevap verirken", "level": "beginner" },
        { "id": "i09", "english": "My greatest strength is my ability to...", "turkish": "En büyük güçlü yönüm ... yeteneğim.", "context": "Güçlü yönleri anlatırken", "level": "beginner" },
        { "id": "i10", "english": "One area I'm actively working to improve is...", "turkish": "Aktif olarak geliştirmeye çalıştığım bir alan...", "context": "Zayıf yönü sorulduğunda", "level": "intermediate" },
        { "id": "i11", "english": "I'm looking for a role where I can...", "turkish": "... yapabileceğim bir rol arıyorum.", "context": "Beklentileri anlatırken", "level": "beginner" },
        { "id": "i12", "english": "Could you tell me more about the team structure?", "turkish": "Ekip yapısı hakkında daha fazla bilgi verebilir misiniz?", "context": "Mülakatta soru sorarken", "level": "intermediate" },
        { "id": "i13", "english": "What does success look like in this role?", "turkish": "Bu rolde başarı nasıl görünüyor?", "context": "Mülakatta soru sorarken", "level": "intermediate" },
        { "id": "i14", "english": "I'm very excited about the opportunity to contribute.", "turkish": "Katkıda bulunma fırsatı için çok heyecanlıyım.", "context": "Kapanışta", "level": "intermediate" },
        { "id": "i15", "english": "When can I expect to hear back from you?", "turkish": "Sizden ne zaman yanıt bekleyebilirim?", "context": "Mülakat sonunda", "level": "beginner" },
        { "id": "i16", "english": "I believe my background aligns well with this position.", "turkish": "Geçmişimin bu pozisyonla iyi örtüştüğüne inanıyorum.", "context": "Uygunluğunu vurgularken", "level": "intermediate" },
        { "id": "i17", "english": "I'd welcome the chance to elaborate on that.", "turkish": "Bunu daha ayrıntılı açıklama fırsatını memnuniyetle kabul ederim.", "context": "Daha fazla konuşmak istediğinde", "level": "advanced" },
        { "id": "i18", "english": "I'm open to discussing the compensation package.", "turkish": "Ücret paketi hakkında görüşmeye açığım.", "context": "Maaş konusunu açarken", "level": "intermediate" },
        { "id": "i19", "english": "I have a few questions, if that's alright.", "turkish": "Birkaç sorum var, uygunsa.", "context": "Soru sormadan önce", "level": "beginner" },
        { "id": "i20", "english": "Thank you so much for your time today.", "turkish": "Bugün ayırdığınız vakit için çok teşekkürler.", "context": "Mülakat sonunda", "level": "beginner" }
      ]
    },
    {
      "id": "salary",
      "title": "Ücret Görüşmesi",
      "icon": "currency-dollar",
      "color": "#15803D",
      "phrases": [
        { "id": "s01", "english": "I'd like to discuss my compensation.", "turkish": "Ücretimi görüşmek istiyorum.", "context": "Konuyu açarken", "level": "intermediate" },
        { "id": "s02", "english": "Based on my research, the market rate for this role is...", "turkish": "Araştırmama göre bu rol için piyasa ücreti...", "context": "Araştırmaya dayanarak konuşurken", "level": "intermediate" },
        { "id": "s03", "english": "I was expecting something closer to...", "turkish": "Daha yakın bir rakam bekliyordum...", "context": "Karşı teklif yaparken", "level": "intermediate" },
        { "id": "s04", "english": "Is there any flexibility on the base salary?", "turkish": "Taban maaşta herhangi bir esneklik var mı?", "context": "Müzakere kapısı açarken", "level": "intermediate" },
        { "id": "s05", "english": "I've consistently exceeded my targets and I believe that warrants a review.", "turkish": "Sürekli olarak hedeflerimi aştım ve bunun bir değerlendirmeyi hak ettiğine inanıyorum.", "context": "Zam isterken gerekçe gösterirken", "level": "advanced" },
        { "id": "s06", "english": "I'm open to discussing the full compensation package.", "turkish": "Tam ücret paketi hakkında görüşmeye açığım.", "context": "Esnekliğini gösterirken", "level": "intermediate" },
        { "id": "s07", "english": "Could we revisit this in three months?", "turkish": "Üç ay içinde bunu tekrar ele alabilir miyiz?", "context": "Hemen zam alamayınca", "level": "intermediate" },
        { "id": "s08", "english": "I appreciate the offer. Could I have a day to consider?", "turkish": "Teklif için teşekkürler. Düşünmek için bir gün alabilir miyim?", "context": "Teklifi hemen kabul etmeden önce", "level": "intermediate" },
        { "id": "s09", "english": "My current package is..., so I'm looking for a step up.", "turkish": "Mevcut paketim ..., bu yüzden bir adım yukarı bakıyorum.", "context": "Mevcut maaşını referans verirken", "level": "intermediate" },
